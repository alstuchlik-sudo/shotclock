<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Feedback — ShotClock' }) %>
</head>
<body>
  <%- include('partials/header') %>
  <main class="container">
    <div class="card connect-card">
      <% if (error) { %>
        <h1>Couldn't record your feedback</h1>
        <div class="alert alert-error"><%= error %></div>
      <% } else { %>
        <h1>Thanks for your feedback!</h1>
        <p class="subtitle">You rated this briefing <%= rating %> out of 5.</p>
        <% if (feedbackText) { %>
          <p class="hint">&ldquo;<%= feedbackText %>&rdquo;</p>
        <% } %>
      <% } %>
      <a href="/pre-match" class="btn btn-secondary">Back to Pre-Match</a>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
