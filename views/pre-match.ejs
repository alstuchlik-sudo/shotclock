<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Pre-Match report — ShotClock' }) %>
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/demo-banner', { demoMode: typeof report !== 'undefined' && report && report.account && report.account.brokerName === 'Demo Broker' }) %>

  <main class="container">
    <div class="card connect-card">
      <h1>Get your Pre-Match report</h1>
      <p class="subtitle">Pick your timezone and generate today's matchup snapshot on demand.</p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/pre-match" id="pre-match-form">
        <select name="timezone" class="timezone-select" required>
          <option value="" disabled <%= !(report && report.timezone) ? 'selected' : '' %>>Select your timezone&hellip;</option>
          <% timezones.forEach(function (tz) { %>
            <option value="<%= tz %>" <%= (report && report.timezone === tz) ? 'selected' : '' %>><%= tz %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn btn-primary btn-large">Get my Pre-Match report</button>
      </form>

      <% if (report) { %>
        <% if (report.mapped.foul) { %>
          <div class="alert alert-error">Foul called. Your margin level is inside the risk zone, discipline check needed before your day starts.</div>
        <% } %>

        <div class="stats-grid">
          <div class="stat-tile">
            <span class="stat-value"><%= report.mapped.shotClockSeconds %>s</span>
            <span class="stat-label">Shot Clock</span>
          </div>
          <div class="stat-tile">
            <span class="badge <%= report.mapped.foul ? 'badge-danger' : 'badge-success' %>"><%= report.mapped.foul ? 'Foul' : 'Clean' %></span>
            <span class="stat-label">Discipline</span>
          </div>
          <div class="stat-tile">
            <span class="stat-value"><%= report.mapped.boxScore.points >= 0 ? '+' : '' %><%= report.mapped.boxScore.points %></span>
            <span class="stat-label">Points</span>
          </div>
        </div>

        <dl class="account-details">
          <dt>Your local time</dt>
          <dd><%= report.localTimeAtSend %> (<%= report.timezone %>)</dd>
          <dt>Broker</dt>
          <dd><%= report.account.brokerName || '—' %></dd>
          <dt>Account type</dt>
          <dd><%= report.account.accountType || '—' %></dd>
          <dt>Balance</dt>
          <dd><%= report.account.balance != null ? report.account.balance + ' ' + (report.account.depositAsset || '') : '—' %></dd>
          <dt>Margin</dt>
          <dd><%= report.account.margin != null ? report.account.margin + ' ' + (report.account.depositAsset || '') : '—' %></dd>
          <dt>Margin level</dt>
          <dd><%= report.mapped.boxScore.marginLevel != null ? report.mapped.boxScore.marginLevel + '%' : 'No positions open' %></dd>
          <dt>Exposure</dt>
          <dd><%= report.mapped.boxScore.exposure %> lots</dd>
        </dl>

        <h2>Open positions</h2>
        <% if (!report.positions || report.positions.length === 0) { %>
          <p class="empty-state">No open positions right now.</p>
        <% } else { %>
          <table class="attempts-table">
            <thead>
              <tr>
                <th>Symbol</th>
                <th>Side</th>
                <th>Volume (lots)</th>
                <th>Pips</th>
                <th>Profit</th>
              </tr>
            </thead>
            <tbody>
              <% report.positions.forEach(function (p) { %>
                <tr>
                  <td><%= p.symbol %></td>
                  <td><%= p.side %></td>
                  <td><%= p.volumeInLots %></td>
                  <td><%= p.pips %></td>
                  <td><%= p.profit %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>

        <p class="hint">This is the matchup you're heading into. Come back after your trading day for the Post-Game recap.</p>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
