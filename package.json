    "mongoose": "^8.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "mongodb": "^6.10.0",
    "mongodb-memory-server": "^11.2.0"
  },
  "allowScripts": {
    "mongodb-memory-server@11.2.0": true,
    "fsevents@2.3.2": true
