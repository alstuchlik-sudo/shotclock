MONGODB_URI=mongodb://127.0.0.1:27017/shotclock-connect
SESSION_SECRET=replace-with-a-long-random-string
CTRADER_MCP_URL=http://127.0.0.1:9876/mcp/
PORT=3000
# Set to true only on the publicly shared/Vercel deployment. Skips the real
# cTrader Desktop MCP call and returns clearly-labeled simulated data instead,
# since a public URL has no reachable local cTrader Desktop to call.
DEMO_MODE=false
